# CUTEkit tool config
#
# Each item under `tools:` is a single tool (aka app, package), so they are organized by tool (rather than method of install)
# 
#
# Install model:
# - backend: apt
#     Installed with `apt install`
#     Use `package`
# - any other backend
#     Written to `mise.toml` and installed by mise
#     Use `source` if you have a specific source you want to pull from
#
# These files are also generated and are *overwritten* if they exist:
# - post_install -> goes to 4-post-install-steps.md
# - reference    -> goes to tool-reference.md
# - shell_setup  _> goes to zshrc.setup

shell:
  family: zsh
  setup_file: .zshrc.setup

tools:
  - name: git
    backend: apt
    package: git
    post_install:
      - Set user.name and user.email
    reference:
      - Used for cloning repos and version control

  - name: openssh
    backend: apt
    package: openssh-client
    post_install:
      - Generate an SSH key if needed
      - Add the public key to GitHub
    reference:
      - Needed for SSH-based Git operations

  - name: yazi
    backend: github
    source: sxyazi/yazi
    version: latest
    reference:
      - Installs both `yazi` and `ya`

  - name: nnn
    backend: github
    source: jarun/nnn
    version: latest
    post_install:
      - The installed binary is named nnn-emoji-static, not nnn
      - 'Run: ln -sf ~/.local/share/mise/installs/github-jarun-nnn/<version>/nnn-emoji-static ~/.local/bin/nnn'
    reference:
      - Release asset name does not match the expected command name, linked to ~/.local/bin/nnn

  - name: fzf
    backend: aqua
    source: junegunn/fzf
    version: latest
    shell_setup:
      - 'source <(fzf --zsh)'

  - name: github-cli
    backend: aqua
    source: cli/cli
    version: latest
    post_install:
      - Run `gh auth login`

  - name: wrangler
    backend: npm
    source: wrangler
    version: latest

  - name: gemini-cli
    backend: npm
    source: "@google/gemini-cli"
    version: latest

  - name: codex
    backend: npm
    source: "@openai/codex"
    version: latest
    post_install:
      - Set `OPENAI_API_KEY`, or run `codex` and follow prompts

  - name: zoxide
    backend: curl
    url: https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh
    installed_check: command -v zoxide
    shell_setup:
      - 'eval "$(zoxide init zsh)"'
    reference:
      - Smarter cd command; use `z` to jump to frequented directories

  - name: pyenv
    backend: curl
    url: https://pyenv.run
    installed_check: '[ -d "$HOME/.pyenv" ]'
    apt_deps:
      - libssl-dev
      - zlib1g-dev
      - libbz2-dev
      - libreadline-dev
      - libsqlite3-dev
      - libncursesw5-dev
      - libffi-dev
      - liblzma-dev
      - tk-dev
    shell_setup:
      - 'export PYENV_ROOT="$HOME/.pyenv"'
      - '[[ -d "$PYENV_ROOT/bin" ]] && export PATH="$PYENV_ROOT/bin:$PATH"'
      - 'eval "$(pyenv init - zsh)"'
    reference:
      - Python version manager installed into `~/.pyenv`

  - name: jless
    backend: cargo
    source: jless
    version: latest

  - name: watchexec
    backend: cargo
    source: watchexec-cli
    version: latest
